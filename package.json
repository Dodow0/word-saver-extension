{
  "name": "wordsaver-extension",
  "version": "1.3.0",
  "description": "浏览器单词本插件 - 选词查释义、管理单词本、导出 Excel/TXT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:zip": "vite build && node scripts/pack.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
